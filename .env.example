# Optional: URL for the Android client APK (header "Download Android app" button).
# If unset, the app serves /releases/android-client.apk (place the file in public/releases/).
# Example for GitHub Releases:
# NEXT_PUBLIC_ANDROID_APK_URL=https://github.com/YOUR_ORG/YOUR_REPO/releases/latest/download/android-client.apk
